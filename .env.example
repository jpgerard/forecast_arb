# Kalshi API Configuration
# Get your API credentials from: https://kalshi.com/settings/api
KALSHI_API_KEY_ID=your_api_key_id_here

# Path to RSA private key PEM file (for authenticated requests using RSA-PSS SHA256)
# Download from Kalshi dashboard and save to a file
KALSHI_PRIVATE_KEY_PATH=/path/to/your/private_key.pem

# Set to 'true' to use demo API (https://demo-api.kalshi.co)
# Leave blank or 'false' for production (https://api.kalshi.com)
KALSHI_DEMO_MODE=false

# OpenAI API Configuration
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Interactive Brokers Configuration
# Host where TWS/IB Gateway is running
IBKR_HOST=127.0.0.1
# Port: 7496 for live TWS
IBKR_PORT=7496
# Client ID (must be unique if multiple clients connect)
IBKR_CLIENT_ID=19
